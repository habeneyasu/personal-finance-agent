# ============================================================
# PFIP MVP — Environment Variables Template
# Copy this file to .env.local for local dev
# Copy to .env.staging / .env.production for AWS deployment
# NEVER commit files with real values to git
# ============================================================

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=local                          # local | staging | production

# ── Local Database (Docker) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=pfip
DB_USER=pfip_admin
DB_PASSWORD=REPLACE_WITH_LOCAL_DB_PASSWORD

# ── AWS Database (Aurora Serverless v2) ──────────────────────
# Set this when deploying to AWS — overrides DB_HOST/PORT/etc
DB_SECRET_ARN=arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:pfip/staging/db-credentials-XXXXXX

# ── AWS Configuration ─────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_ACCESS_KEY

# ── Cognito (production auth) ─────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_REGION=us-east-1

# ── JWT (local auth) ──────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# ── AI Provider ──────────────────────────────────────────────
# Cerebras (local/demo) — get free key from https://console.cerebras.ai
# When set, Cerebras is used instead of Bedrock
CEREBRAS_API_KEY=REPLACE_WITH_CEREBRAS_API_KEY
CEREBRAS_MODEL=llama-3.3-70b

# AWS Bedrock (production fallback when CEREBRAS_API_KEY is not set)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# ── MCP Server ────────────────────────────────────────────────
PFIP_API_KEY=REPLACE_WITH_STRONG_API_KEY_FOR_MCP_AUTH

# ── Lambda Function Names (set after terraform apply) ─────────
INCOME_FUNCTION=pfip-staging-income-agent
EXPENSE_FUNCTION=pfip-staging-expense-agent
SAVINGS_FUNCTION=pfip-staging-savings-agent
INSIGHTS_FUNCTION=pfip-staging-insights-agent

# ── Frontend API URL (set after terraform apply) ──────────────
# Get from: terraform -chdir=infra output api_gateway_url
VITE_API_URL=https://XXXXXXXXXX.execute-api.us-east-1.amazonaws.com/api/v1

# ── LangSmith (optional — LLM tracing) ───────────────────────
# Get free key from https://smith.langchain.com
# Set LANGCHAIN_TRACING_V2=true to enable tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=REPLACE_WITH_LANGSMITH_API_KEY
LANGCHAIN_PROJECT=pfip-mvp
