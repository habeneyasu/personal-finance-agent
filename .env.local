# Local development environment variables
# Used by migrate.py, seed_demo.py, and agent handlers when running locally
# DO NOT commit real credentials — this file is gitignored

DB_HOST=localhost
DB_PORT=5433
DB_NAME=pfip
DB_USER=pfip_admin
DB_PASSWORD=pfip_local_password

# Leave DB_SECRET_ARN empty for local dev (falls back to above vars)
DB_SECRET_ARN=

# ── AI Provider ───────────────────────────────────────────────
# Get free API key from: https://console.cerebras.ai
# When set, Cerebras is used instead of Bedrock (works locally without AWS)
CEREBRAS_API_KEY=csk-fyr2enk8t33kptm6jefymr3jkc2j4d9rd36dtmf4wwde34w6
CEREBRAS_MODEL=llama3.1-8b

# Dummy values for local testing (agents won't call real AWS services)
AWS_DEFAULT_REGION=us-east-1
ENVIRONMENT=local
